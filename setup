#!/bin/bash
# memory-graph setup
#
# Mode A — in-place (after curl extraction):
#   curl -sL https://github.com/SundaraSwani/memory-graph/archive/refs/heads/main.tar.gz \
#     | tar -xz --strip-components=1 && bash setup
#
# Mode B — remote (toolkit already at ~/.cursor/skills/memory-graph/):
#   cd /your/project && ~/.cursor/skills/memory-graph/setup

set -euo pipefail

SCRIPT_DIR=$(cd "$(dirname "$0")" && pwd)
TARGET=$(pwd)
REPO_NAME=$(basename "$TARGET")

# Detect mode:
# In-place = setup script is running from the target project itself
# Remote   = setup script lives somewhere else (e.g. ~/.cursor/skills/memory-graph/)
if [ "$SCRIPT_DIR" = "$TARGET" ]; then
  MODE="inplace"
else
  MODE="remote"
fi

echo "memory-graph setup ($MODE mode) → $TARGET ($REPO_NAME)"
echo ""

# ── In-place mode: files already extracted, just configure ────────────────
if [ "$MODE" = "inplace" ]; then

  # Fix permissions
  chmod +x "$TARGET/setup" "$TARGET/post-commit.sh" \
           "$TARGET/.cursor/hooks/on-session-end.sh" \
           "$TARGET/.cursor/hooks/compress-memory.py" \
           "$TARGET/scripts/test.sh" \
           "$TARGET/scripts/test-static.sh" \
           "$TARGET/scripts/test-compress-sandbox.sh" 2>/dev/null || true

  # Dev hooks: pre-push runs sandbox tests before git push
  if [ -f "$TARGET/scripts/install-dev-hooks.sh" ]; then
    bash "$TARGET/scripts/install-dev-hooks.sh" 2>/dev/null || true
  fi

  # Replace [REPO_NAME] placeholder in rules and CLAUDE.md
  for f in \
    "$TARGET/.cursor/rules/main.mdc" \
    "$TARGET/.cursor/rules/sdlc.mdc" \
    "$TARGET/CLAUDE.md"; do
    [ -f "$f" ] && sed -i '' "s/\[REPO_NAME\]/$REPO_NAME/g" "$f" 2>/dev/null || true
  done
  echo "[ok] .cursor/ configured for $REPO_NAME"

# ── Remote mode: copy files into target project ───────────────────────────
else

  # Hooks
  mkdir -p "$TARGET/.cursor/hooks"
  cp "$SCRIPT_DIR/.cursor/hooks/on-session-end.sh" "$TARGET/.cursor/hooks/"
  chmod +x "$TARGET/.cursor/hooks/on-session-end.sh"
  cp "$SCRIPT_DIR/.cursor/hooks/compress-memory.py" "$TARGET/.cursor/hooks/"
  chmod +x "$TARGET/.cursor/hooks/compress-memory.py"

  if [ ! -f "$TARGET/.cursor/hooks.json" ]; then
    cp "$SCRIPT_DIR/.cursor/hooks.json" "$TARGET/.cursor/"
  else
    echo "[warn] .cursor/hooks.json exists — add stop hook manually from memory-graph"
  fi
  echo "[ok] .cursor/hooks/ ready"

  # Rules
  mkdir -p "$TARGET/.cursor/rules"
  for rule in main.mdc sdlc.mdc; do
    if [ ! -f "$TARGET/.cursor/rules/$rule" ]; then
      sed "s/\[REPO_NAME\]/$REPO_NAME/g" \
        "$SCRIPT_DIR/.cursor/rules/$rule" > "$TARGET/.cursor/rules/$rule"
    fi
  done
  echo "[ok] .cursor/rules/ ready"

  # Root files
  [ ! -f "$TARGET/CLAUDE.md" ] && \
    sed "s/\[REPO_NAME\]/$REPO_NAME/g" "$SCRIPT_DIR/CLAUDE.md" > "$TARGET/CLAUDE.md"
  [ ! -f "$TARGET/memory.md" ] && cp "$SCRIPT_DIR/memory.md" "$TARGET/memory.md"
  [ ! -f "$TARGET/.gitignore" ] && cp "$SCRIPT_DIR/.gitignore" "$TARGET/.gitignore"
  [ ! -f "$TARGET/post-commit.sh" ] && \
    cp "$SCRIPT_DIR/post-commit.sh" "$TARGET/post-commit.sh" && \
    chmod +x "$TARGET/post-commit.sh"
  mkdir -p "$TARGET/sessions" "$TARGET/memory" "$TARGET/.memory-graph" "$TARGET/scripts"
  cp "$SCRIPT_DIR/.memory-graph/ollama.example.yaml" "$TARGET/.memory-graph/" 2>/dev/null || true
  cp "$SCRIPT_DIR/.cursor/hooks/semantic-compress-ollama.py" "$TARGET/.cursor/hooks/" 2>/dev/null || true
  chmod +x "$TARGET/.cursor/hooks/semantic-compress-ollama.py" 2>/dev/null || true
  cp "$SCRIPT_DIR/scripts/check-ollama.sh" "$TARGET/scripts/" 2>/dev/null || true
  cp "$SCRIPT_DIR/scripts/enable-semantic-ollama.sh" "$TARGET/scripts/" 2>/dev/null || true
  echo "[ok] root files ready"

fi

# ── Both modes: git post-commit hook ──────────────────────────────────────
if [ -d "$TARGET/.git" ]; then
  HOOK_FILE="$TARGET/.git/hooks/post-commit"
  HOOK_LINE='bash "$(git rev-parse --show-toplevel)/post-commit.sh"'
  if [ ! -f "$HOOK_FILE" ]; then
    printf '#!/bin/bash\n%s\n' "$HOOK_LINE" > "$HOOK_FILE"
    chmod +x "$HOOK_FILE"
    echo "[ok] .git/hooks/post-commit installed"
  elif ! grep -q "post-commit\.sh" "$HOOK_FILE" 2>/dev/null; then
    printf '\n# memory-graph\n%s\n' "$HOOK_LINE" >> "$HOOK_FILE"
    echo "[ok] Appended to existing post-commit hook"
  else
    echo "[ok] post-commit hook already set"
  fi
else
  echo "[warn] No .git found — run 'git init' then re-run setup to install post-commit hook"
fi

# ── Both modes: graphify ──────────────────────────────────────────────────
echo ""
echo "Checking graphify..."
python3 -c "import graphify" 2>/dev/null || \
  python3 -m pip install graphifyy -q 2>/dev/null || \
  python3 -m pip install graphifyy -q --break-system-packages 2>/dev/null || \
  echo "[warn] graphify install failed — run: pip install graphifyy"
python3 -c "import graphify" 2>/dev/null && echo "[ok] graphify ready" || echo "[warn] graphify not found"

# ── Both modes: gstack (opt-in) ───────────────────────────────────────────
echo ""
if [ "${INSTALL_GSTACK:-}" = "1" ]; then
  echo "Checking gstack..."
  GSTACK_DIR="$HOME/.cursor/skills/gstack"
  if [ ! -d "$GSTACK_DIR" ]; then
    echo "Installing gstack for Cursor..."
    git clone --single-branch --depth 1 https://github.com/garrytan/gstack.git "$GSTACK_DIR" 2>/dev/null && \
      (cd "$GSTACK_DIR" && ./setup --host cursor 2>/dev/null) && \
      echo "[ok] gstack installed" || \
      echo "[warn] gstack install failed — run: git clone https://github.com/garrytan/gstack.git $GSTACK_DIR"
  else
    echo "[ok] gstack already installed"
  fi
else
  echo "[skip] gstack not installed (optional). Run: INSTALL_GSTACK=1 bash setup"
fi

# ── Done ──────────────────────────────────────────────────────────────────
echo ""
echo "Done. memory-graph active in $TARGET"
echo ""
echo "Next:"
echo "  /graphify .              — build knowledge graph, populate god nodes in main.mdc"
echo "  graph-scout subagent     — query graph without loading it into chat (see main.mdc)"
echo "  /grill-me                — optional, for new features"
echo "  INSTALL_GSTACK=1 bash setup  — add gstack SDLC skills (/spec, /review, /qa, /ship)"
echo "  bash scripts/test.sh         — run sandbox tests before push"
